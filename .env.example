# ============================================================================
# SKYPULSE AI — Snowflake Connection Configuration
# ============================================================================
# Copy this file to .env and fill in your Snowflake account details.
# The deploy.sh script will read these automatically.
#
# To find your account identifier:
#   - Log into Snowflake → bottom-left corner → hover over your name
#   - Format: <orgname>-<accountname> (e.g., myorg-myaccount)
#   - OR use the full locator: xy12345.us-west-2.aws
# ============================================================================

# Snowflake Account (REQUIRED)
# Format: <orgname>-<accountname> OR <account_locator>.<region>.<cloud>
SNOWFLAKE_ACCOUNT=your-org-your-account

# Snowflake User (REQUIRED)
SNOWFLAKE_USER=your_username

# Snowflake Password (REQUIRED)
# For key-pair auth, leave empty and configure in ~/.snowsql/config
SNOWFLAKE_PASSWORD=your_password

# Role (default: ACCOUNTADMIN — needed for initial setup)
SNOWFLAKE_ROLE=ACCOUNTADMIN

# Warehouse (default: SKYPULSE_TRANSFORM_WH — created by the setup script)
SNOWFLAKE_WAREHOUSE=SKYPULSE_TRANSFORM_WH

# ============================================================================
# Alternative: Named Connection
# ============================================================================
# If you prefer to use ~/.snowsql/config, set only this:
# SNOWSQL_CONNECTION=skypulse
#
# And add to ~/.snowsql/config:
# [connections.skypulse]
# accountname = your-org-your-account
# username = your_username
# password = your_password
# rolename = ACCOUNTADMIN
# warehousename = SKYPULSE_TRANSFORM_WH
# ============================================================================

# Skip confirmation prompt (useful for CI/CD)
# SKIP_CONFIRM=true
